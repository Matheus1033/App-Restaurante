generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

model MenuItem {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    name        String
    description String?
    price       Float
    createdAt   DateTime @default(now())
}

model User {
    id        Int      @id @default(auto()) @map("_id") @db.ObjectId
    name      String
    phone     String
    email     String   @unique
    password  String
    createdAt DateTime @default(now())
}
